# Copy to .env for local dev. Docker sets these via docker-compose.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset to use a local SQLite file (fast dev/tests).
# In Docker this points at the postgres service.
# DATABASE_URL=postgres://nava:nava@db:5432/nava

# Frontend origin(s) allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Payment gateway: "fake" (offline, deterministic) or "zarinpal" (sandbox).
PAYMENT_GATEWAY=fake
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
ZARINPAL_SANDBOX=True
# Where the gateway sends the user back after payment (frontend route).
PAYMENT_CALLBACK_URL=http://localhost:3000/settings?payment=callback
